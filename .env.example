# =====================================================================
# Second Brain — Environment Variables
# Copy this file to `.env` and edit the values you need.
# =====================================================================

# --- Paths -----------------------------------------------------------
# Absolute or relative path to the Obsidian vault directory.
SECOND_BRAIN_VAULT_PATH=./vault

# Where ChromaDB stores its persistent collections.
SECOND_BRAIN_CHROMA_DIR=./memory/chroma_db

# Embedding cache directory.
SECOND_BRAIN_EMBED_CACHE=./memory/embeddings_cache

# --- LM Studio (local LLM, 100% offline) ----------------------------
# Open LM Studio, download an instruct model (e.g. Llama 3.1 8B Instruct,
# Qwen 2.5 7B, Mistral 7B Instruct), load it, then click "Start Server".
# Default port is 1234. URL must end with /v1.
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Leave empty to auto-detect the loaded model via /v1/models.
# Or pin a specific model name, e.g.:
# LMSTUDIO_MODEL=lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF
LMSTUDIO_MODEL=

# Tip: this also works with any OpenAI-compatible local server
# (vLLM, llama.cpp's llama-server, LocalAI). Just point the URL at it.

# --- Embeddings ------------------------------------------------------
# Sentence-transformers model name for ChromaDB embeddings.
SECOND_BRAIN_EMBED_MODEL=all-MiniLM-L6-v2

# --- Behaviour -------------------------------------------------------
# Default language for summaries (ISO code: en, fr, ...).
SECOND_BRAIN_LANG=fr

# Logging level: DEBUG | INFO | WARNING | ERROR
SECOND_BRAIN_LOG_LEVEL=INFO

# --- Scheduler -------------------------------------------------------
# Hours between full orchestration cycles.
SECOND_BRAIN_FULL_CYCLE_HOURS=6

# --- Optional API server --------------------------------------------
SECOND_BRAIN_API_HOST=127.0.0.1
SECOND_BRAIN_API_PORT=8765

# --- Optional search providers --------------------------------------
SERPAPI_API_KEY=
